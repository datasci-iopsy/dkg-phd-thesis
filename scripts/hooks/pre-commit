#!/usr/bin/env bash
# Pre-commit hooks:
#   1. Lint staged R/Python files        (SKIP_R_LINT=1 / SKIP_RUFF=1 to bypass)
#   2. Block accidental lock file commits (ALLOW_LOCK_COMMIT=1 to bypass)
set -euo pipefail

# Dotfiles lint hooks (managed by ~/.dotfiles -- never edit this line)
bash "$HOME/.claude/hooks/repo-pre-commit.sh"

# --- Lock file guard ---
LOCK_FILES=()
for f in uv.lock uvr.lock; do
    if git diff --cached --name-only | grep -qx "$f"; then
        LOCK_FILES+=("$f")
    fi
done

[ ${#LOCK_FILES[@]} -eq 0 ] && exit 0

echo ""
echo "WARNING: Lock file(s) staged for commit:"
for f in "${LOCK_FILES[@]}"; do echo "  - $f"; done
echo ""

if [ "${ALLOW_LOCK_COMMIT:-0}" = "1" ]; then
    echo "ALLOW_LOCK_COMMIT=1 set -- proceeding."
    exit 0
fi

echo "Dependencies are frozen. If this lock update is intentional:"
echo "  ALLOW_LOCK_COMMIT=1 git commit ..."
echo ""
exit 1
