echo "|------ Installing python (if needed)"
pyenv install --skip-existing

echo "|------ Installing dependencies"
watch_file uv.lock
STAMP=".venv/.uv-install-stamp"
if [ ! -f "$STAMP" ] || [ "uv.lock" -nt "$STAMP" ]; then
    uv lock --check || { echo "ERROR: uv.lock is out of sync with pyproject.toml. Run 'uv lock' to sync."; return 1; }
    uv sync --frozen --all-groups && touch "$STAMP"
else
    echo "  > Dependencies up to date"
fi

echo "|------ Activating virtualenv"
dotenv .env
source .venv/bin/activate
echo "  > Activated env: $VIRTUAL_ENV_PROMPT"
