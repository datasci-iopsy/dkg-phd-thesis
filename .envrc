echo "|------ Installing python (if needed)"
pyenv install --skip-existing

echo "|------ Installing dependencies"
watch_file poetry.lock
STAMP=".venv/.poetry-install-stamp"
if [ ! -f "$STAMP" ] || [ "poetry.lock" -nt "$STAMP" ]; then
    poetry check --lock || { echo "ERROR: poetry.lock is out of sync with pyproject.toml. Run 'poetry lock --no-update' to sync."; return 1; }
    poetry install --with fn-qualtrics-scheduling,fn-intake-confirmation,fn-followup-scheduling,fn-followup-response,dev && touch "$STAMP"
else
    echo "  > Dependencies up to date"
fi

echo "|------ Activating virtualenv"
dotenv .env
eval "$(poetry env activate)"
echo "  > Activated env: $VIRTUAL_ENV_PROMPT"
